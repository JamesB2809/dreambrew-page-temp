  {%- comment -%} ============== COMPARISON TABLE ============== {%- endcomment -%}
  <section class="db__cream-panel" style="background: transparent; padding-top: 32px;">
    <h2 class="db__h2">
      {{ section.settings.compare_heading_1 }}
      <span class="accent">{{ section.settings.compare_heading_2 }}</span>
      {{ section.settings.compare_heading_3 }}
    </h2>

    <div class="db__compare-wrap">
      <table class="db__compare-table">
        <thead>
          <tr>
            <th></th>
            <th class="db__compare-col-db db-logo-cell">
              {% if section.settings.compare_db_logo != blank %}
                <img src="{{ section.settings.compare_db_logo | image_url: width: 160 }}" alt="Dream Brew">
              {% else %}
                Dream Brew
              {% endif %}
            </th>
            <th>{{ section.settings.compare_col_2 }}</th>
            <th>{{ section.settings.compare_col_3 }}</th>
            <th>{{ section.settings.compare_col_4 }}</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            {% if block.type == 'compare_row' %}
              <tr {{ block.shopify_attributes }}>
                <td>{{ block.settings.label }}</td>
                {% for col in (1..4) %}
                  {%- assign ck = 'col_' | append: col -%}
                  <td {% if col == 1 %}class="db__compare-col-db"{% endif %}>
                    {% case block.settings[ck] %}
                      {% when 'check' %}
                        <svg class="check" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                      {% when 'question' %}
                        <svg class="x" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><text x="12" y="17" text-anchor="middle" font-size="14" fill="#fff" font-weight="900">?</text></svg>
                      {% when 'x' %}
                        <svg class="x" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10"/><path d="M8 8l8 8M16 8l-8 8" stroke="#fff" stroke-width="2.5"/></svg>
                      {% else %}
                        —
                    {% endcase %}
                  </td>
                {% endfor %}
              </tr>
            {% endif %}
          {% endfor %}
        </tbody>
      </table>
    </div>

    {% if section.settings.compare_image != blank %}
      <div class="db__big-img"><img src="{{ section.settings.compare_image | image_url: width: 1200 }}" alt=""></div>
    {% endif %}

    <a href="{{ section.settings.get_cta_url }}" class="db__cta db__cta--small db__cta--solid">{{ section.settings.get_cta_label }}</a>
  </section>

  {%- comment -%} ============== FUND-A-DREAM CTA ============== {%- endcomment -%}
  <section class="db__cta-block">
    <h2>
      {{ section.settings.fund_heading_1 }}
      <span class="accent">{{ section.settings.fund_heading_2 }}</span>
    </h2>
    <p>{{ section.settings.fund_body }}</p>
    <a href="{{ section.settings.fund_cta_url }}" class="db__cta db__cta--small db__cta--solid">{{ section.settings.fund_cta_label }}</a>
  </section>

  {%- comment -%} ============== FAQ ============== {%- endcomment -%}
  <section class="db__faq">
    <h2>{{ section.settings.faq_heading }}</h2>
    {% for block in section.blocks %}
      {% if block.type == 'faq' %}
        <div class="db__faq-item" {{ block.shopify_attributes }} data-db-faq>
          <button class="db__faq-q" type="button">{{ block.settings.question }}</button>
          <div class="db__faq-a">{{ block.settings.answer }}</div>
        </div>
      {% endif %}
