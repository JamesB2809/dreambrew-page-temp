      {{ section.settings.closer_line_1 }}<br>
      {{ section.settings.closer_line_2 }}
    </h2>
  </section>

  {%- comment -%} ============== HIDDEN PRODUCT FORM ============== {%- endcomment -%}
  <form id="db-cart-form-{{ section.id }}" action="{{ routes.cart_add_url }}" method="post" enctype="multipart/form-data" hidden>
    <input type="hidden" name="id" data-db-variant value="">
    <input type="hidden" name="quantity" value="1">
  </form>

</div>

{%- comment -%} ============== VARIANT MAP (Liquid → JS) ============== {%- endcomment -%}
<script>
(function () {
  var section = document.querySelector('[data-section-id="{{ section.id }}"]');
  if (!section) return;

  // Variant lookup: { tier (12|24): { flavor (purpose|focus): variantId } }
  var VARIANTS = {
    "12": {
      "purpose": {{ starter.variants | where: 'title', 'PURPOSE COFFEE' | map: 'id' | first | default: starter.variants.first.id | json }},
      "focus":   {{ starter.variants | where: 'title', 'FOCUS COFFEE'   | map: 'id' | first | default: starter.variants.first.id | json }}
    },
    "24": {
      "purpose": {{ dream.variants   | where: 'title', 'PURPOSE COFFEE' | map: 'id' | first | default: dream.variants.first.id   | json }},
      "focus":   {{ dream.variants   | where: 'title', 'FOCUS COFFEE'   | map: 'id' | first | default: dream.variants.first.id   | json }}
    }
  };

  var state = { tier: "12", flavor: "purpose" };

  // Flavor toggle
  section.querySelectorAll('[data-db-flavor]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      state.flavor = btn.getAttribute('data-db-flavor');
      section.querySelectorAll('[data-db-flavor]').forEach(function (b) {
        var on = b === btn;
        b.classList.toggle('is-active', on);
        b.setAttribute('aria-checked', on);
      });
    });
  });

  // Tier toggle
  section.querySelectorAll('[data-db-tier]').forEach(function (lbl) {
    lbl.addEventListener('click', function () {
      state.tier = lbl.getAttribute('data-db-tier');
      section.querySelectorAll('[data-db-tier]').forEach(function (l) {
        l.classList.toggle('is-active', l === lbl);
      });
      var input = lbl.querySelector('input');
      if (input) input.checked = true;
    });
  });

  // Thumb gallery (just visual swap of hero image)
  var heroImg = section.querySelector('.db__product-hero img');
  section.querySelectorAll('[data-db-thumb]').forEach(function (t) {
    t.addEventListener('click', function () {
      section.querySelectorAll('[data-db-thumb]').forEach(function (x) { x.classList.remove('is-active'); });
      t.classList.add('is-active');
      var img = t.querySelector('img');
      if (heroImg && img) heroImg.src = img.src.replace(/width=\d+/, 'width=1000');
    });
  });

  // FAQ accordion
  section.querySelectorAll('[data-db-faq]').forEach(function (item) {
    item.querySelector('.db__faq-q').addEventListener('click', function () {
      item.classList.toggle('is-open');
    });
  });

  // Carousel
  var car = section.querySelector('[data-db-carousel]');
  if (car) {
    var track = car.querySelector('.db__carousel-track');
    var dots = car.querySelector('[data-db-dots]');
    var cards = track.querySelectorAll('.db__card');
    cards.forEach(function (_, i) {
      var d = document.createElement('span');
      if (i === 0) d.classList.add('is-active');
      dots.appendChild(d);
    });
    function scrollByCard(dir) {
      var card = track.querySelector('.db__card');
      if (!card) return;
      track.scrollBy({ left: dir * (card.offsetWidth + 16), behavior: 'smooth' });
    }
    car.querySelector('[data-db-prev]').addEventListener('click', function () { scrollByCard(-1); });
    car.querySelector('[data-db-next]').addEventListener('click', function () { scrollByCard(1); });
    track.addEventListener('scroll', function () {
      var i = Math.round(track.scrollLeft / (track.querySelector('.db__card').offsetWidth + 16));
      dots.querySelectorAll('span').forEach(function (s, idx) { s.classList.toggle('is-active', idx === i); });
    });
  }

  // Add to cart
  section.querySelectorAll('[data-db-add]').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var vid = (VARIANTS[state.tier] || {})[state.flavor];
      if (!vid) {
        alert('Sorry, that combination is not available.');
        return;
      }
      btn.disabled = true;
      var origLabel = btn.textContent;
      btn.textContent = 'Adding…';
      fetch('{{ routes.cart_add_url }}.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: [{ id: vid, quantity: 1 }] })
      })
        .then(function (r) { return r.json(); })
        .then(function () { window.location.href = '{{ routes.cart_url }}'; })
        .catch(function () {
          btn.disabled = false;
          btn.textContent = origLabel;
          alert('Could not add to cart. Please try again.');
        });
    });
  });
})();
</script>

