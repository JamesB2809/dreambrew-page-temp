{%- comment -%}
  DreamBrew landing page section.
  Built from Figma "Frame 1168". Mobile-first 600px max content column,
  expands to 720px on desktop. Uses theme header & footer.
{%- endcomment -%}

{%- liquid
  assign starter = all_products[section.settings.product_12_handle]
  assign dream   = all_products[section.settings.product_24_handle]
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

{% style %}
  .db {
    --db-pink: #d24c7f;
    --db-pink-dark: #c8215d;
    --db-brown: #402a11;
    --db-yellow: #ffde17;
    --db-cream: #fff6e3;
    --db-cream-rot: #f9e8d4;
    --db-grey: #c8c8c8;
    --db-red: #f44336;
    font-family: 'Montserrat', system-ui, -apple-system, sans-serif;
    color: var(--db-brown);
    line-height: 1.4;
    overflow-x: hidden;
    max-width: 600px;
    margin: 0 auto;
    background: #fff;
  }
  .db * { box-sizing: border-box; }
  .db__wrap { max-width: 600px; margin: 0 auto; padding: 0 16px; }
  .db__wrap--wide { max-width: 720px; }

  /* Top pink banner */
  .db__banner { background: var(--db-pink); padding: 18px 16px; text-align: center; }
  .db__banner img { height: 32px; width: auto; }

  /* Hero */
  .db__hero { position: relative; padding: 56px 16px 24px; text-align: center; overflow: hidden; }
  .db__hero-bg { position: absolute; inset: 0; z-index: 0; pointer-events: none; }
  .db__hero-bg img { width: 100%; height: 100%; object-fit: cover; }
  .db__hero-bg::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to bottom, #fff 0%, rgba(255,255,255,0) 55%); }
  .db__hero-inner { position: relative; z-index: 1; }
  .db__h1 { font-weight: 900; font-size: clamp(34px, 8vw, 48px); line-height: 1; letter-spacing: -0.04em; text-transform: uppercase; margin: 0 0 16px; }
  .db__h1 .accent { display: block; color: var(--db-pink); }
  .db__hero-sub { font-size: clamp(16px, 4.5vw, 21px); max-width: 510px; margin: 0 auto 32px; }
  .db__hero-sub b, .db__hero-sub strong { font-weight: 700; }

  /* Feature pills row */
  .db__features { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; max-width: 460px; margin: 0 auto 28px; }
  .db__feature { display: flex; flex-direction: column; align-items: center; gap: 6px; text-align: center; font-weight: 500; font-size: clamp(14px, 3.8vw, 18px); }
  .db__feature-icon { width: 56px; height: 48px; display: grid; place-items: center; }
  .db__feature-icon svg { width: 42px; height: 36px; }

  /* Big CTA pill */
  .db__cta { display: inline-flex; align-items: center; justify-content: center; width: 100%; max-width: 540px; min-height: 76px; padding: 18px 32px; border-radius: 999px; background: var(--db-pink); color: #fff; font-weight: 700; font-size: clamp(22px, 5vw, 30px); text-transform: uppercase; text-decoration: none; border: 2px solid var(--db-brown); box-shadow: 0 6px 6px rgba(0,0,0,0.09), 0 13px 8px rgba(0,0,0,0.05); transition: transform .15s ease; }
  .db__cta:hover { transform: translateY(-1px); color: #fff; }
  .db__cta--small { min-height: 52px; max-width: 320px; padding: 14px 24px; font-size: 18px; }
  .db__cta--solid { box-shadow: 3px 4px 0 var(--db-brown); }

  /* Reassurance line */
  .db__reassure { display: flex; align-items: center; justify-content: center; gap: 10px; margin: 16px 0 28px; font-weight: 500; font-size: 18px; }
  .db__reassure svg { color: var(--db-pink); width: 28px; height: 24px; flex: 0 0 auto; }

  /* Money-given pill */
  .db__money-pill { display: inline-flex; align-items: center; gap: 8px; background: var(--db-pink-dark); color: #fff; padding: 10px 18px; border-radius: 999px; font-weight: 800; text-transform: uppercase; letter-spacing: -0.03em; font-size: 16px; margin: 24px auto; }
  .db__money-pill svg { width: 20px; height: 20px; }

  /* Cream rotated panel sections */
  .db__cream-panel { position: relative; padding: 80px 16px 64px; text-align: center; }
  .db__cream-panel::before { content: ''; position: absolute; inset: 24px -20px; background: var(--db-cream-rot); transform: rotate(-3.34deg); z-index: 0; }
  .db__cream-panel > * { position: relative; z-index: 1; }
  .db__h2 { font-weight: 900; font-size: clamp(28px, 7vw, 40px); line-height: 1; letter-spacing: -0.04em; text-transform: uppercase; margin: 0 0 28px; }
  .db__h2 .accent { display: block; color: var(--db-pink); }
  .db__h2 .accent-inline { color: var(--db-pink); }

  /* Testimonial carousel */
  .db__carousel { position: relative; margin: 0 -16px; }
  .db__carousel-track { display: flex; gap: 16px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 0 24px 16px; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
  .db__carousel-track::-webkit-scrollbar { display: none; }
  .db__card { flex: 0 0 78%; max-width: 382px; scroll-snap-align: center; background: #fff; border: 1px solid var(--db-pink); border-radius: 10px; box-shadow: 0 4px 4px rgba(0,0,0,0.25); overflow: hidden; text-align: left; }
  .db__card-img { aspect-ratio: 380 / 247; background: #a87777; }
  .db__card-img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .db__card-body { padding: 24px; }
  .db__card-title { font-weight: 700; font-size: 20px; letter-spacing: -0.03em; text-transform: capitalize; margin: 0 0 12px; }
  .db__card-text { font-size: 16px; line-height: 1.45; margin: 0 0 20px; }
  .db__card-tag { display: inline-flex; align-items: center; gap: 8px; background: var(--db-yellow); padding: 8px 14px; border-radius: 999px; font-weight: 600; font-size: 16px; }
  .db__card-tag svg { width: 20px; height: 20px; color: var(--db-brown); }
  .db__carousel-nav { display: flex; align-items: center; justify-content: center; gap: 10px; margin: 16px 0 0; }
  .db__carousel-nav button { width: 38px; height: 38px; border-radius: 50%; border: none; background: var(--db-pink); color: #fff; display: grid; place-items: center; cursor: pointer; }
  .db__carousel-dots { background: var(--db-yellow); border-radius: 999px; padding: 6px 14px; display: inline-flex; gap: 6px; align-items: center; height: 28px; }
  .db__carousel-dots span { width: 7px; height: 7px; border-radius: 50%; background: var(--db-brown); opacity: 0.3; transition: opacity .2s; }
  .db__carousel-dots span.is-active { opacity: 1; }

  /* Coffee strip divider */
  .db__strip { width: 100%; height: 64px; object-fit: cover; display: block; }

  /* Checklist */
  .db__checklist { list-style: none; padding: 0; margin: 0 auto; max-width: 480px; display: flex; flex-direction: column; gap: 24px; }
  .db__checklist li { display: flex; align-items: center; gap: 18px; font-size: clamp(18px, 5vw, 27px); }
  .db__check-circle { flex: 0 0 40px; width: 40px; height: 40px; border-radius: 50%; background: var(--db-yellow); display: grid; place-items: center; }
  .db__check-circle svg { width: 24px; height: 24px; color: var(--db-brown); }

  /* Product image card */
  .db__product-hero { border: 2px solid var(--db-brown); border-radius: 8px; box-shadow: 3px 3px 0 var(--db-brown); overflow: hidden; max-width: 488px; margin: 24px auto; aspect-ratio: 488 / 402; background: #f5f5f5; }
  .db__product-hero img { width: 100%; height: 100%; object-fit: cover; display: block; }

  .db__thumb-row { display: flex; gap: 9px; justify-content: center; margin: 16px 0 28px; }
  .db__thumb { width: 64px; height: 64px; border: 1.5px solid rgba(64,42,17,0.16); border-radius: 8px; overflow: hidden; cursor: pointer; background: #fff; padding: 0; }
  .db__thumb.is-active { border-color: var(--db-brown); }
  .db__thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* Section subhead label */
  .db__label { font-weight: 900; font-size: 21px; text-transform: uppercase; margin: 0 0 18px; max-width: 488px; margin-inline: auto; text-align: left; }

  /* Flavor selector */
  .db__flavors { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; max-width: 360px; margin: 0 auto 32px; }
  .db__flavor { background: none; padding: 0; border: 0; cursor: pointer; text-align: center; }
  .db__flavor-card { border: 2px solid var(--db-grey); border-radius: 8px; box-shadow: 3px 3px 0 var(--db-brown); background: #fff; overflow: hidden; aspect-ratio: 150 / 146; position: relative; display: flex; flex-direction: column; justify-content: flex-end; }
  .db__flavor-card img { width: 60%; height: 70%; object-fit: contain; align-self: center; margin-top: 8px; }
  .db__flavor-label { background: var(--db-grey); color: #fff; padding: 10px 6px; font-weight: 900; font-size: 11px; text-transform: uppercase; }
  .db__flavor.is-active .db__flavor-card { border-color: var(--db-yellow); }
  .db__flavor.is-active .db__flavor-label { background: var(--db-yellow); color: var(--db-brown); }

  /* Pricing card */
  .db__pricing { background: var(--db-cream); border: 2px solid var(--db-brown); border-radius: 10px; box-shadow: 4px 4px 0 var(--db-brown); padding: 28px 22px; max-width: 488px; margin: 0 auto; }
  .db__pricing-title { font-weight: 900; font-size: 19px; text-transform: uppercase; margin: 0 0 16px; }
  .db__tier { background: #fff; border: 1px solid var(--db-brown); border-radius: 24px; padding: 16px 20px 16px 50px; margin-bottom: 14px; cursor: pointer; position: relative; display: block; }
  .db__tier input { position: absolute; opacity: 0; pointer-events: none; }
  .db__tier::before { content: ''; position: absolute; left: 18px; top: 50%; transform: translateY(-50%); width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--db-brown); background: #fff; }
  .db__tier.is-active::before { background: radial-gradient(circle, var(--db-pink) 40%, #fff 45%); }
  .db__tier-name { font-weight: 900; font-size: 17px; text-transform: uppercase; margin: 0 0 4px; }
  .db__tier-price { font-size: 17px; font-weight: 700; }
  .db__tier-price s { font-weight: 400; opacity: 0.65; margin-left: 6px; font-size: 15px; }
  .db__tier-perday { display: block; font-weight: 700; font-size: 14px; margin-top: 4px; }

  .db__perks { list-style: none; padding: 0; margin: 24px 0 28px; display: flex; flex-direction: column; gap: 14px; }
  .db__perks li { display: flex; align-items: center; gap: 12px; font-size: 17px; }
  .db__perks svg { width: 18px; height: 18px; color: var(--db-brown); flex: 0 0 auto; }
  .db__perks b { font-weight: 700; }

  .db__pricing .db__cta { width: 100%; min-height: 64px; font-size: 22px; box-shadow: 3px 4px 0 var(--db-brown); }

  /* One-time card */
  .db__onetime { background: rgba(255,246,227,0); border: 1px solid var(--db-brown); border-radius: 8px; padding: 18px 22px; max-width: 488px; margin: 24px auto 32px; }
  .db__onetime h3 { font-weight: 900; font-size: 17px; text-transform: uppercase; margin: 0 0 6px; }
  .db__onetime .price { font-weight: 700; font-size: 17px; }
  .db__onetime .price s { font-weight: 400; opacity: 0.65; margin-left: 6px; font-size: 15px; }
  .db__onetime p { margin: 6px 0 0; font-weight: 700; font-size: 14px; }

  /* Tastes Like */
  .db__tastes { display: flex; gap: 32px; justify-content: center; margin: 28px 0 48px; }
  .db__taste { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .db__taste-bubble { width: 67px; height: 67px; background: var(--db-pink); border-radius: 50%; display: grid; place-items: center; transform: rotate(-8.5deg); }
  .db__taste-bubble svg { width: 34px; height: 34px; color: #fff; }
  .db__taste-name { font-weight: 700; font-size: 18px; }

  /* Comparison table */
  .db__compare-wrap { background: var(--db-cream); border: 1.5px solid var(--db-brown); border-radius: 8px; box-shadow: 3px 3px 0 var(--db-brown); padding: 24px 12px; max-width: 488px; margin: 24px auto; position: relative; }
  .db__compare-table { width: 100%; border-collapse: collapse; position: relative; z-index: 1; }
  .db__compare-table th, .db__compare-table td { padding: 14px 4px; text-align: center; font-weight: 700; font-size: 13px; vertical-align: middle; border-bottom: 1px solid var(--db-brown); }
  .db__compare-table th:first-child, .db__compare-table td:first-child { text-align: left; padding-left: 8px; }
  .db__compare-table tr:last-child td { border-bottom: 0; }
  .db__compare-col-db { background: var(--db-yellow); position: relative; }
  .db__compare-table .db-logo-cell { padding-top: 12px; padding-bottom: 12px; }
  .db__compare-table .db-logo-cell img { height: 28px; width: auto; }
  .db__compare-table svg { width: 16px; height: 16px; vertical-align: middle; }
  .db__compare-table .check { color: var(--db-brown); }
  .db__compare-table .x { color: var(--db-red); }

  /* Big image */
  .db__big-img { width: 100%; aspect-ratio: 509 / 400; background: #5f5f5f; margin: 32px 0; overflow: hidden; }
  .db__big-img img { width: 100%; height: 100%; object-fit: cover; }

  /* CTA section */
  .db__cta-block { padding: 32px 16px 40px; text-align: center; }
  .db__cta-block h2 { font-weight: 900; font-size: clamp(28px, 7vw, 40px); line-height: 1.05; letter-spacing: -0.04em; margin: 0 0 16px; }
  .db__cta-block .accent { color: var(--db-pink); }
  .db__cta-block p { font-size: 20px; line-height: 1.4; max-width: 460px; margin: 0 auto 24px; }
  .db__cta-block p b { font-weight: 700; }

  /* FAQ */
  .db__faq { max-width: 488px; margin: 0 auto; padding: 24px 16px 32px; }
  .db__faq h2 { font-weight: 900; font-size: 30px; text-transform: uppercase; text-align: center; margin: 0 0 28px; }
  .db__faq-item { background: #fff; border: 1px solid var(--db-brown); border-radius: 5px; box-shadow: 2px 2px 0 var(--db-brown); margin-bottom: 16px; }
  .db__faq-q { width: 100%; background: none; border: 0; padding: 18px 50px 18px 22px; font-weight: 900; font-size: 14px; text-align: left; cursor: pointer; position: relative; color: var(--db-brown); }
  .db__faq-q::after { content: ''; position: absolute; right: 22px; top: 50%; width: 12px; height: 12px; border-right: 2px solid var(--db-brown); border-bottom: 2px solid var(--db-brown); transform: translateY(-75%) rotate(45deg); transition: transform .2s; }
  .db__faq-item.is-open .db__faq-q::after { transform: translateY(-25%) rotate(-135deg); }
  .db__faq-a { padding: 0 22px; max-height: 0; overflow: hidden; transition: max-height .25s ease, padding .25s ease; font-size: 12px; line-height: 1.45; }
  .db__faq-item.is-open .db__faq-a { padding: 0 22px 18px; max-height: 800px; }
  .db__faq-a ul { padding-left: 18px; margin: 6px 0; }

  .db__faq + .db__center-cta { padding: 8px 16px 40px; text-align: center; }

  /* Dark closer banner */
  .db__closer { position: relative; padding: 48px 16px; text-align: center; color: #fff; overflow: hidden; }
  .db__closer-bg { position: absolute; inset: 0; background: rgba(41,25,7,0.84); z-index: 0; }
  .db__closer-bg img { width: 100%; height: 100%; object-fit: cover; }
  .db__closer h2 { position: relative; z-index: 1; font-weight: 700; font-size: clamp(22px, 6vw, 28px); margin: 0; line-height: 1.2; }

  /* Sticky add-to-cart helper hidden by default — can be unhidden with section setting */
  .db__sticky-cart { display: none; }

{% endstyle %}

<div class="db" data-section-id="{{ section.id }}">

  {%- if section.settings.show_top_banner -%}
    <div class="db__banner">
      {% if section.settings.banner_logo != blank %}
        <img src="{{ section.settings.banner_logo | image_url: width: 220 }}" alt="Dream Brew" loading="eager">
      {% else %}
        <strong style="color:#fff;letter-spacing:0.2em;text-transform:uppercase;">Dream Brew</strong>
      {% endif %}
    </div>
  {%- endif -%}

  {%- comment -%} ============== HERO ============== {%- endcomment -%}
  <section class="db__hero">
    {% if section.settings.hero_bg != blank %}
      <div class="db__hero-bg"><img src="{{ section.settings.hero_bg | image_url: width: 1200 }}" alt="" loading="eager"></div>
    {% endif %}
    <div class="db__hero-inner">
      <h1 class="db__h1">
        {{ section.settings.hero_heading_1 }}
        <span class="accent">{{ section.settings.hero_heading_2 }}</span>
      </h1>
      <p class="db__hero-sub">{{ section.settings.hero_subhead }}</p>

      <div class="db__features">
        {% for i in (1..3) %}
          {%- assign t = 'hero_feature_' | append: i | append: '_text' -%}
          <div class="db__feature">
            <div class="db__feature-icon">
              <svg viewBox="0 0 42 36" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 4 C3 1, 5 1, 8 1 L34 1 C37 1, 39 3, 39 6 L39 24 C39 30, 33 35, 21 35 C9 35, 3 30, 3 24 Z" stroke="#d24c7f" stroke-width="2.5" fill="none"/>
              </svg>
            </div>
            <span>{{ section.settings[t] }}</span>
          </div>
        {% endfor %}
      </div>

      <a href="{{ section.settings.hero_cta_url }}" class="db__cta">{{ section.settings.hero_cta_label }}</a>

      <p class="db__reassure">
        <svg viewBox="0 0 30 26" fill="currentColor" aria-hidden="true"><path d="M15 0 L19 9 L29 10 L21 17 L24 26 L15 21 L6 26 L9 17 L1 10 L11 9 Z"/></svg>
        {{ section.settings.guarantee_text }}
      </p>
    </div>
  </section>

  {%- comment -%} ============== TESTIMONIAL CARDS ============== {%- endcomment -%}
  <section class="db__cream-panel">
    <h2 class="db__h2">
      {{ section.settings.testi_heading_1 }}
      <span class="accent">{{ section.settings.testi_heading_2 }}</span>
    </h2>

    <div class="db__money-pill">
      <svg viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M10 17.5l-1.5-1.4C3.4 11.6 0 8.6 0 4.9 0 2 2.2 0 5 0c1.6 0 3 .7 4 1.9C10 .7 11.5 0 13 0c2.8 0 5 2 5 4.9 0 3.7-3.4 6.7-8.5 11.2L10 17.5z"/></svg>
      {{ section.settings.money_pill_text }}
    </div>

    <div class="db__carousel" data-db-carousel>
      <div class="db__carousel-track">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <article class="db__card" {{ block.shopify_attributes }}>
              <div class="db__card-img">
                {% if block.settings.image != blank %}
                  <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
                {% endif %}
              </div>
              <div class="db__card-body">
                <h3 class="db__card-title">{{ block.settings.title }}</h3>
                <p class="db__card-text">{{ block.settings.text }}</p>
                <span class="db__card-tag">
                  <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/><path d="M8 12l3 3 5-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {{ block.settings.tag }}
                </span>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
      <div class="db__carousel-nav">
        <button type="button" data-db-prev aria-label="Previous">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M9 2 L4 7 L9 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="db__carousel-dots" data-db-dots></div>
        <button type="button" data-db-next aria-label="Next">
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 2 L10 7 L5 12" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </div>
    </div>
  </section>

  {%- comment -%} ============== STRIP ============== {%- endcomment -%}
  {% if section.settings.strip_image != blank %}
    <img class="db__strip" src="{{ section.settings.strip_image | image_url: width: 1200 }}" alt="" loading="lazy">
  {% endif %}

  {%- comment -%} ============== CHECKLIST ============== {%- endcomment -%}
  <section class="db__cream-panel" style="background: transparent;">
    <h2 class="db__h2">
      {{ section.settings.check_heading_1 }}
      <span class="accent">{{ section.settings.check_heading_2 }}</span>
    </h2>
    <ul class="db__checklist">
      {% for block in section.blocks %}
        {% if block.type == 'check_item' %}
          <li {{ block.shopify_attributes }}>
            <span class="db__check-circle">
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12 L10 17 L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            {{ block.settings.text }}
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </section>

  {%- comment -%} ============== START CHASING / PRODUCT BUILDER ============== {%- endcomment -%}
  <section class="db__wrap--wide" style="padding: 32px 16px 64px; text-align: center;">
    <h2 class="db__h2">
      {{ section.settings.builder_heading_1 }}
      <span class="accent-inline">{{ section.settings.builder_heading_2 }}</span>
    </h2>

    <div class="db__product-hero">
      {% if section.settings.product_hero_image != blank %}
        <img src="{{ section.settings.product_hero_image | image_url: width: 1000 }}" alt="">
      {% elsif starter.featured_image %}
        <img src="{{ starter.featured_image | image_url: width: 1000 }}" alt="{{ starter.title | escape }}">
      {% endif %}
    </div>

    {% if section.settings.thumb_1 != blank or section.settings.thumb_2 != blank or section.settings.thumb_3 != blank or section.settings.thumb_4 != blank %}
      <div class="db__thumb-row">
        {% for i in (1..4) %}
          {%- assign tk = 'thumb_' | append: i -%}
          {% if section.settings[tk] != blank %}
            <button type="button" class="db__thumb {% if i == 1 %}is-active{% endif %}" data-db-thumb="{{ i }}">
              <img src="{{ section.settings[tk] | image_url: width: 200 }}" alt="">
            </button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    <p class="db__label">{{ section.settings.flavor_label }}</p>
    <div class="db__flavors" role="radiogroup" aria-label="Flavor">
      <button type="button" class="db__flavor is-active" data-db-flavor="purpose" role="radio" aria-checked="true">
        <div class="db__flavor-card">
          {% if section.settings.flavor_purpose_image != blank %}
            <img src="{{ section.settings.flavor_purpose_image | image_url: width: 240 }}" alt="">
          {% endif %}
          <div class="db__flavor-label">{{ section.settings.flavor_purpose_label }}</div>
        </div>
      </button>
      <button type="button" class="db__flavor" data-db-flavor="focus" role="radio" aria-checked="false">
        <div class="db__flavor-card">
          {% if section.settings.flavor_focus_image != blank %}
            <img src="{{ section.settings.flavor_focus_image | image_url: width: 240 }}" alt="">
          {% endif %}
          <div class="db__flavor-label">{{ section.settings.flavor_focus_label }}</div>
        </div>
      </button>
    </div>

    {%- comment -%} ============== PRICING / AUTOSHIP ============== {%- endcomment -%}
    <div class="db__pricing">
      <h3 class="db__pricing-title">{{ section.settings.pricing_heading }}</h3>

      <label class="db__tier is-active" data-db-tier="12">
        <input type="radio" name="db-tier" value="12" checked>
        <span class="db__tier-name">{{ section.settings.tier_12_name }}</span>
        <span class="db__tier-price">
          {{ section.settings.tier_12_price }}
          <s>{{ section.settings.tier_12_compare }}</s>
        </span>
        <span class="db__tier-perday">{{ section.settings.tier_12_perday }}</span>
      </label>

      <label class="db__tier" data-db-tier="24">
        <input type="radio" name="db-tier" value="24">
        <span class="db__tier-name">{{ section.settings.tier_24_name }}</span>
        <span class="db__tier-price">
          {{ section.settings.tier_24_price }}
          <s>{{ section.settings.tier_24_compare }}</s>
        </span>
        <span class="db__tier-perday">{{ section.settings.tier_24_perday }}</span>
      </label>

      <ul class="db__perks">
        {% for i in (1..4) %}
          {%- assign p = 'perk_' | append: i -%}
          {% if section.settings[p] != blank %}
            <li>
              <svg viewBox="0 0 18 18" fill="none" aria-hidden="true"><circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="2"/><path d="M5 9l3 3 5-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              {{ section.settings[p] }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <button type="button" class="db__cta db__cta--solid" data-db-add>{{ section.settings.add_cta_label }}</button>
    </div>

    {%- comment -%} ============== ONE-TIME CARD ============== {%- endcomment -%}
    <div class="db__onetime">
      <h3>{{ section.settings.onetime_heading }}</h3>
      <div class="price">
        {{ section.settings.onetime_price }}
        {% if section.settings.onetime_compare != blank %}<s>{{ section.settings.onetime_compare }}</s>{% endif %}
      </div>
      {% if section.settings.onetime_note != blank %}<p>{{ section.settings.onetime_note }}</p>{% endif %}
    </div>

    {%- comment -%} ============== TASTES LIKE ============== {%- endcomment -%}
    <p style="font-weight:700;font-size:17px;margin:8px 0 0;">{{ section.settings.tastes_heading }}</p>
    <div class="db__tastes">
      {% for i in (1..3) %}
        {%- assign tn = 'taste_' | append: i | append: '_name' -%}
        {%- assign ti = 'taste_' | append: i | append: '_icon' -%}
        <div class="db__taste">
          <div class="db__taste-bubble">
            {% case section.settings[ti] %}
              {% when 'snowflake' %}
                <svg viewBox="0 0 24 24" fill="none"><path d="M12 2v20M4 6l16 12M4 18L20 6M2 12h20" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/></svg>
              {% when 'drop' %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2c-3 5-7 9-7 13a7 7 0 0014 0c0-4-4-8-7-13z"/></svg>
              {% else %}
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3 7h7l-5.5 4 2 7L12 16l-6.5 4 2-7L2 9h7z"/></svg>
            {% endcase %}
          </div>
          <span class="db__taste-name">{{ section.settings[tn] }}</span>
        </div>
      {% endfor %}
