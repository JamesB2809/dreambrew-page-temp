    <div class="db__center-cta" style="text-align:center;margin-top:24px;">
      <button type="button" class="db__cta db__cta--small db__cta--solid" data-db-add>{{ section.settings.cart_cta_label }}</button>
    </div>
  </section>

  {%- comment -%} ============== CLOSER BANNER ============== {%- endcomment -%}
  <section class="db__closer">
    {% if section.settings.closer_bg != blank %}
      <div class="db__closer-bg"><img src="{{ section.settings.closer_bg | image_url: width: 1200 }}" alt=""></div>
    {% else %}
